<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero Section with Coffee Theme -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/hero_gradient_bg"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="☕"
                    android:textSize="56sp"
                    android:layout_gravity="center"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Campus Hub"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#2C1B14"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Campus Coffee Companion"
                    android:textSize="14sp"
                    android:textColor="#6F4E37"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:fontStyle="italic"/>

            </LinearLayout>

            <!-- Decorative Coffee Steam -->
            <TextView
                android:id="@+id/steam1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~~~"
                android:textSize="28sp"
                android:textColor="#D4B895"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="30dp"
                android:alpha="0.6"/>

            <TextView
                android:id="@+id/steam2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~~~"
                android:textSize="22sp"
                android:textColor="#D4B895"
                android:layout_alignParentTop="true"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="45dp"
                android:layout_marginEnd="50dp"
                android:alpha="0.4"/>

        </RelativeLayout>

        <!-- Navigation Buttons using YOUR existing nav_bg -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginTop="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAbout"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/nav_bg"
                app:backgroundTint="@null"
                android:text="📖 About"
                android:textColor="#2C1B14"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEvents"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/nav_bg"
                app:backgroundTint="@null"
                android:text="📅 Events"
                android:textColor="#2C1B14"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="12dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLost"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="6dp"
                android:background="@drawable/nav_bg"
                app:backgroundTint="@null"
                android:text="🔍 Lost"
                android:textColor="#2C1B14"
                android:textStyle="bold"
                android:textSize="14sp"
                android:padding="12dp"/>

        </LinearLayout>

        <!-- About Section - Enhanced Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#ebdfce">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☕"
                        android:textSize="32sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="About Campus Hub"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#2C1B14"
                        android:layout_marginStart="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✨"
                        android:textSize="24sp"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#D4B895"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Campus Hub is your one-stop destination for campus life! Stay updated with the latest events, workshops, and never lose your belongings again. We help students track events and find lost items easily in one cozy place."
                    android:textSize="14sp"
                    android:textColor="#261403"
                    android:lineSpacingExtra="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☕ Fresh Brews • 📅 Daily Events • 🔍 Lost &amp; Found"
                        android:textSize="11sp"
                        android:textColor="#6F4E37"
                        android:textStyle="italic"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Clubs Section Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Clubs with Us ✨"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2C1B14"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <!-- Clubs Section - Enhanced with 4 clubs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_margin="8dp"
            android:background="@drawable/clubs_section_bg">

            <!-- Row 1 - Tech and Art Clubs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Tech Club Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTech"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#F5F0E8"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💻"
                            android:textSize="44sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tech Club"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C1B14"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Code &amp; Coffee"
                            android:textSize="10sp"
                            android:textColor="#6F4E37"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Art Club Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardArt"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#F5F0E8"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎨"
                            android:textSize="44sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Art Club"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C1B14"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Latte Art"
                            android:textSize="10sp"
                            android:textColor="#6F4E37"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Row 2 - Music and Sports Clubs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Music Club Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMusic"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#F5F0E8"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵"
                            android:textSize="44sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Music Club"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C1B14"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jazz Nights"
                            android:textSize="10sp"
                            android:textColor="#6F4E37"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Sports Club Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSports"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#F5F0E8"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚽"
                            android:textSize="44sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sports Club"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2C1B14"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Coffee Kickoff"
                            android:textSize="10sp"
                            android:textColor="#6F4E37"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

        <!-- Upcoming Events Teaser -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#ebdfce">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅"
                        android:textSize="28sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Upcoming This Week"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2C1B14"
                        android:layout_marginStart="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="20sp"/>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D4B895"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="☕"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Coffee &amp; Code Workshop"
                        android:textSize="14sp"
                        android:textColor="#2C1B14"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 25"
                        android:textSize="12sp"
                        android:textColor="#6F4E37"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎨"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Latte Art Masterclass"
                        android:textSize="14sp"
                        android:textColor="#2C1B14"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 27"
                        android:textSize="12sp"
                        android:textColor="#6F4E37"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎵"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Jazz &amp; Coffee Night"
                        android:textSize="14sp"
                        android:textColor="#2C1B14"
                        android:layout_marginStart="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mar 29"
                        android:textSize="12sp"
                        android:textColor="#6F4E37"
                        android:textStyle="bold"/>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewAllEvents"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/nav_bg"
                    app:backgroundTint="@null"
                    android:text="☕ View All Events"
                    android:textColor="#2C1B14"
                    android:textStyle="bold"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ Brewing Connections, One Cup at a Time ☕"
                android:textSize="12sp"
                android:textColor="#6F4E37"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© 2024 Campus Hub"
                android:textSize="10sp"
                android:textColor="#D4B895"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>